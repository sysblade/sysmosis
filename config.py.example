# Krosmosis Configuration
# Copy this file to config.py and update with your values

# ==========================================
# WiFi Settings
# ==========================================
WIFI_SSID = "YourNetworkName"
WIFI_PASSWORD = "YourPassword"
WIFI_TIMEOUT = 10  # Connection timeout in seconds
WIFI_RECONNECT_INTERVAL = 60  # Check WiFi every N seconds

# ==========================================
# Hardware Pin Configuration
# ==========================================

# I2C LCD Display
PIN_LCD_SCL = 22
PIN_LCD_SDA = 21
LCD_I2C_ADDR = 0x27  # Common addresses: 0x27 or 0x3F
LCD_ROWS = 4
LCD_COLS = 20

# Relay Outputs
PIN_PUMP = 12
PIN_INLET_VALVE = 13
PIN_FLUSH_VALVE = 14

# Buzzer
PIN_BUZZER = 32

# Sensor Inputs (active low / NPN opto-isolated)
PIN_LOW_PRESSURE = 25
PIN_HIGH_PRESSURE = 26
PIN_LEAK_SENSOR = 27

# TDS Sensor (analog)
PIN_TDS_SENSOR = 34

# ==========================================
# TDS Calibration
# ==========================================
# Formula: PPM = ADC_VALUE * TDS_FACTOR + TDS_OFFSET
TDS_FACTOR = 0.5
TDS_OFFSET = 0

# ==========================================
# Flush Cycle Settings
# ==========================================
FLUSH_STARTUP_DURATION = 20           # seconds, on every boot
FLUSH_INACTIVITY_INTERVAL_MIN = 86400    # 24h standby before flush
FLUSH_INACTIVITY_INTERVAL_MAX = 172800   # 48h max standby before flush
FLUSH_INACTIVITY_DURATION = 60        # seconds
FLUSH_PRODUCTION_INTERVAL = 0         # 0 = disabled; set e.g. 3600 to flush after 1h production
FLUSH_PRODUCTION_DURATION = 30        # seconds
FLUSH_MANUAL_DURATION = 30            # seconds, when triggered from web UI

# ==========================================
# Watchdog Settings
# ==========================================
WATCHDOG_TIMEOUT = 30000  # Watchdog timeout in milliseconds (30 seconds)

# ==========================================
# Prometheus Metrics Settings
# ==========================================
METRICS_ENABLED = True  # Enable/disable metrics endpoint
METRICS_PORT = 8080  # HTTP port for /metrics endpoint

# ==========================================
# Web Interface Settings
# ==========================================
WEB_ENABLED = True    # Enable HTTP web UI (requires WiFi)
WEB_PORT = 80         # set to 443 when WEB_HTTPS = True

# Authentication (leave unset or empty to disable)
WEB_AUTH_PASSWORD = "changeme"   # password for the web UI login page

# HTTPS (optional — requires cert.pem + key.pem on the device filesystem)
# Generate on your PC:
#   openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem \
#               -days 3650 -nodes -subj "/CN=krosmosis"
# Upload to device:
#   mpremote connect /dev/ttyUSB0 cp cert.pem :cert.pem
#   mpremote connect /dev/ttyUSB0 cp key.pem  :key.pem
WEB_HTTPS = False
WEB_CERT_FILE = "cert.pem"
WEB_KEY_FILE  = "key.pem"

# NOTE: WebREPL has been removed. Use mpremote for OTA file uploads:
#   mpremote connect /dev/ttyUSB0 cp <file> :<file>
